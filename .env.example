DATABASE_URL="postgresql://promptparle:promptparle@localhost:5433/promptparle?schema=public"
ENCRYPTION_KEY="generate_with_openssl_rand_hex_32"
SESSION_SECRET="generate_with_openssl_rand_hex_32"
NEXT_PUBLIC_APP_URL="https://promptparle.com"
APP_NAME="PromptParle"

# Optional: Google Search Console HTML-tag verification code (content= value only)
# GOOGLE_SITE_VERIFICATION=

# Reverse proxy: how many X-Forwarded-For hops to trust (default 1 = nginx)
TRUSTED_PROXY_HOPS=1

# OAuth (optional — enables one-click Google / GitHub signup)
# Redirect URIs:
#   {NEXT_PUBLIC_APP_URL}/api/auth/oauth/google/callback
#   {NEXT_PUBLIC_APP_URL}/api/auth/oauth/github/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Authorized redirect URI in Google Cloud Console must be EXACTLY:
#   https://promptparle.com/api/auth/oauth/google/callback
# Also add Authorized JavaScript origin: https://promptparle.com
# Optional override if Console uses a different URI:
# GOOGLE_REDIRECT_URI=https://promptparle.com/api/auth/oauth/google/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# GitHub Sponsors webhook (optional — admin audit + email on sponsorship events)
# Payload URL: {NEXT_PUBLIC_APP_URL}/api/webhooks/github
# Content type: application/json
# Events: Sponsorship (+ Ping)
# GITHUB_WEBHOOK_SECRET=

# Email (verification) — not required if only OAuth is used
# Preferred: Amazon SES (MAIL_TRANSPORT=ses)
MAIL_TRANSPORT=ses
MAIL_FROM=PromptParle <noreply@promptparle.com>
AWS_REGION=us-east-2
# Optional debug: log verification links server-side
MAIL_DEBUG=false
# Where public /request-invite form emails go (comma-separated).
# Always also emailed to every portal user with isAdmin=true (your account email).
# INVITE_REQUEST_TO=you@example.com
# ADMIN_EMAIL=you@example.com

# Alternatives:
# RESEND_API_KEY=re_xxx
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_TRANSPORT=sendmail
