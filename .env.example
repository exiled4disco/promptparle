DATABASE_URL="postgresql://promptparle:promptparle@localhost:5433/promptparle?schema=public"
ENCRYPTION_KEY="generate_with_openssl_rand_hex_32"
SESSION_SECRET="generate_with_openssl_rand_hex_32"
NEXT_PUBLIC_APP_URL="https://promptparle.com"
APP_NAME="PromptParle"

# Email (verification)
# Preferred: Amazon SES (MAIL_TRANSPORT=ses)
MAIL_TRANSPORT=ses
MAIL_FROM=PromptParle <noreply@promptparle.com>
AWS_REGION=us-east-2
# Optional debug: log verification links server-side
MAIL_DEBUG=false

# Alternatives:
# RESEND_API_KEY=re_xxx
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_TRANSPORT=sendmail
