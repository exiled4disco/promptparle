// PromptParle — core data model for portal MVP

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  /** Null for OAuth-only accounts (Google / GitHub). */
  passwordHash    String?   @map("password_hash")
  plan            String    @default("free")
  /** Portal administrator (invitation manager, etc.). */
  isAdmin         Boolean   @default(false) @map("is_admin")
  emailVerifiedAt DateTime? @map("email_verified_at")
  /** Set when the user finishes or skips the setup walkthrough. Null = show it. */
  onboardedAt     DateTime? @map("onboarded_at")
  /** Last observed client IP (portal login or desktop API). */
  lastIp          String?   @map("last_ip")
  lastCountry     String?   @map("last_country")
  lastCountryCode String?   @map("last_country_code")
  lastIpAt        DateTime? @map("last_ip_at")
  /** When set, account cannot sign in or use API keys. */
  disabledAt      DateTime? @map("disabled_at")
  disabledReason  String?   @map("disabled_reason")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  retentionPolicy String  @default("7d") @map("retention_policy")
  // Stats-only by default: never store prompt/context bodies (session titles only)
  storePrompts    Boolean @default(false) @map("store_prompts")

  // Preferred AI routing (portal ↔ desktop sync)
  preferredProvider     String?  @map("preferred_provider")
  /** JSON map provider→model id, e.g. {"openai":"gpt-4o","grok":"grok-3"} */
  preferredModels       String?  @map("preferred_models") @db.Text
  defaultDial           Int      @default(3) @map("default_dial")
  defaultToolsEnabled   Boolean  @default(true) @map("default_tools_enabled")

  // Desktop Project Connections lockdown (portal Settings → desktop client)
  featProjectPc  Boolean @default(true) @map("feat_project_pc")
  featProjectSsh Boolean @default(true) @map("feat_project_ssh")
  featProjectGit Boolean @default(true) @map("feat_project_git")

  /**
   * Optional API IP/CIDR allowlist for desktop API keys (v1/*).
   * Empty/null = no restriction. Newline or comma separated IPv4 or CIDR.
   * Does NOT gate browser session / Settings (avoids lockout).
   */
  allowedIps String? @map("allowed_ips") @db.Text

  providerCredentials  ProviderCredential[]
  apiKeys              ApiKey[]
  promptRequests       PromptRequest[]
  sessions             Session[]
  emailVerifications   EmailVerificationToken[]
  passwordResetTokens  PasswordResetToken[]
  desktopClients       DesktopClient[]
  oauthAccounts        OAuthAccount[]
  invitationsSent      Invitation[] @relation("InvitationsSent")
  invitationAccepted   Invitation?  @relation("InvitationAccepted")
  feedbackSubmissions  FeedbackSubmission[]
  toolSavingsDaily     ToolSavingsDaily[]

  @@map("users")
}

/**
 * Bug reports and product suggestions from portal or desktop.
 * status: new | read | closed
 * kind: bug | suggest
 * source: portal | desktop
 */
model FeedbackSubmission {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  kind      String   @default("suggest")
  title     String
  body      String   @db.Text
  source    String   @default("portal")
  email     String?
  name      String?
  ip        String?
  country   String?
  userAgent String?  @map("user_agent")
  status    String   @default("new")
  adminNote String?  @map("admin_note") @db.Text
  githubIssue Int?    @map("github_issue")
  githubUrl   String? @map("github_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId])
  @@map("feedback_submissions")
}

/**
 * One-time customer invitation.
 * Flow: admin creates → email with URL → customer completes form →
 * welcome email with code → desktop install validates code → API key → redeemed.
 * status: pending | accepted | redeemed | revoked
 */
model Invitation {
  id              String    @id @default(cuid())
  email           String
  /** Human-readable one-time code, e.g. PP-AB12-CD34 */
  code            String    @unique
  /** Hashed URL token for /invite/[token] (raw token only in email). */
  tokenHash       String    @unique @map("token_hash")
  status          String    @default("pending")
  invitedById     String    @map("invited_by_id")
  acceptedUserId  String?   @unique @map("accepted_user_id")
  note            String?
  expiresAt       DateTime  @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  acceptedAt      DateTime? @map("accepted_at")
  redeemedAt      DateTime? @map("redeemed_at")
  revokedAt       DateTime? @map("revoked_at")

  invitedBy    User  @relation("InvitationsSent", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedUser User? @relation("InvitationAccepted", fields: [acceptedUserId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status, createdAt])
  @@map("invitations")
}

/** One-time password reset links (hashed token, short TTL). */
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  usedAt    DateTime? @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/** Linked Google / GitHub identities (simple signup, no password required). */
model OAuthAccount {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  provider       String
  providerUserId String   @map("provider_user_id")
  email          String?
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

/** Password login failure / lockout tracking. */
model LoginAttempt {
  id          String    @id @default(cuid())
  key         String    @unique
  fails       Int       @default(0)
  lockedUntil DateTime? @map("locked_until")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("login_attempts")
}

/** Security-relevant events (no secrets). */
model AuditEvent {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String
  ip        String?
  meta      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_events")
}

/** Concurrent desktop UI seats (Free plan = 1 active client). */
model DesktopClient {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  clientId   String   @map("client_id")
  hostname   String?
  platform   String?
  appVersion String?  @map("app_version")
  lastSeenAt DateTime @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([userId, lastSeenAt])
  @@map("desktop_clients")
}

// Per-tool aggregate token savings pushed by local-first desktop clients.
// Privacy: aggregate counts/labels only. no prompt/context bodies ever stored.
model ToolSavingsDaily {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  day         String // "YYYY-MM-DD" (UTC)
  tool        String // fleet | relevant_slice | git | ssh_read | error_brief | chat_memory | budget_cap | framing
  provider    String
  charsSaved  Int      @default(0) @map("chars_saved")
  occurrences Int      @default(0)
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day, tool, provider])
  @@index([userId])
  @@map("tool_savings_daily")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  usedAt    DateTime? @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model ProviderCredential {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  provider     String
  label        String?
  encryptedKey String    @map("encrypted_key")
  keyLastFour  String    @map("key_last_four")
  status       String    @default("active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastUsedAt   DateTime? @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("provider_credentials")
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  name       String
  keyHash    String    @unique @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  scope      String    @default("desktop")
  status     String    @default("active")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  revokedAt  DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

model PromptRequest {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  provider            String
  model               String?
  optimizationProfile String   @default("general") @map("optimization_profile")
  originalTokens      Int      @default(0) @map("original_tokens")
  optimizedTokens     Int      @default(0) @map("optimized_tokens")
  status              String   @default("completed")
  /** Short list snippet (deprecated: stats-only mode leaves this null) */
  promptPreview       String?  @map("prompt_preview")
  /** Desktop chat/session title (not prompt body). */
  sessionTitle        String?  @map("session_title")
  /** Client chat id for grouping (local UI). */
  clientSessionId     String?  @map("client_session_id")
  /** Full original input — product no longer stores bodies (always null). */
  originalText        String?  @map("original_text") @db.Text
  /** Full optimized prompt — product no longer stores bodies (always null). */
  optimizedText       String?  @map("optimized_text") @db.Text
  originalTruncated   Boolean  @default(false) @map("original_truncated")
  optimizedTruncated  Boolean  @default(false) @map("optimized_truncated")
  errorMessage        String?  @map("error_message")
  createdAt           DateTime @default(now()) @map("created_at")
  /**
   * Soft-hide from Request History UI. Token stats (aggregates) still count this row.
   * Deleting a session/history entry sets this; does not destroy usage totals.
   */
  historyHiddenAt DateTime? @map("history_hidden_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, historyHiddenAt])
  @@index([userId, sessionTitle])
  @@map("prompt_requests")
}
